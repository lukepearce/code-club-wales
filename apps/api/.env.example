# ---------------------------------------------------------------------------
# apps/api (Hono + Better Auth + Drizzle/Postgres) — local dev defaults.
# Copy to .env (gitignored). Railway provides these in production.
# ---------------------------------------------------------------------------

# Postgres connection string. Locally: `docker compose up -d db` (Postgres 16),
# or any local Postgres. Required — no default.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codeclub

# Port the Hono server listens on.
PORT=3000

# Better Auth secret (sign cookies/tokens). Use a long random value in prod.
BETTER_AUTH_SECRET=dev-secret-change-me-in-production

# Public base URL of this API (where Better Auth is mounted).
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated browser origins allowed to call the API (the SPA).
TRUSTED_ORIGINS=http://localhost:5173

# Session cookie domain for cross-subdomain sharing (my.* / api.*).
# Leave UNSET locally so cookies work on localhost. Prod: .codeclub.wales
# COOKIE_DOMAIN=.codeclub.wales

# Google OAuth (optional; may stay empty for now). HUMAN HANDOFF: real client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated usernames bootstrapped as Organisers. A join with a matching
# username is auto-flagged is_organiser AND auto-admitted in the same transaction.
ORGANISER_USERNAMES=
