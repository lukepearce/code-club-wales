# apps/spa (Vite + React) — local dev. Copy to .env.local (gitignored).

# Base URL of the Hono API where Better Auth is mounted (no trailing slash).
# Better Auth's React client appends /api/auth itself.
VITE_API_URL=http://localhost:3000

# Cloudflare Turnstile site key for the join widget. Defaults to Cloudflare's
# documented dev TEST site key (always passes, renders locally). HUMAN HANDOFF:
# set the real site key in production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
