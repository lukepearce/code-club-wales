# The grill-me lesson (lessons/phase-1-grill-me.html) calls /api/grill, which
# proxies to an OpenAI-compatible chat API. The key lives ONLY on the server
# (Vercel env var) and is never sent to the browser.
#
# Local dev:   copy to .env.local and run `vercel dev`
# Production:  set BOTH vars below in the Vercel project
#              (Settings -> Environment Variables)

# --- OpenRouter ------------------------------------------------------------
# Get a key at https://openrouter.ai/keys
GRILL_API_KEY=sk-or-...

# Model. Use the PAID Llama variant — it's ~$0.13/M tokens, which is roughly
# half a cent per grilling session per kid (a club night is a few cents), and
# it's reliable.
GRILL_MODEL=meta-llama/llama-3.3-70b-instruct

# NOTE on free models: the ":free" variants (e.g. meta-llama/llama-3.3-70b-instruct:free)
# are heavily rate-limited upstream and frequently return 429 mid-session — not
# usable for a live club. They cost $0 but aren't dependable. If you want to try
# anyway, set GRILL_MODEL to a ":free" id and expect occasional "the coach had a
# hiccup" messages.

# Optional override (defaults to OpenRouter):
# GRILL_BASE_URL=https://openrouter.ai/api/v1

# --- Upgrade to Claude later (no code change) ------------------------------
# Same key, OpenAI-compatible — just change the model:
#   GRILL_MODEL=anthropic/claude-sonnet-4-6


# ===========================================================================
# Accounts / auth (Better Auth) — closed access, magic-link sign-in.
# The AI coach (/api/grill) is gated: only allow-listed Crew members who are
# signed in can call it. All of these must be set in the Vercel project too.
# ===========================================================================

# Neon Postgres connection string (free tier). Create a project at
# https://neon.tech and copy the pooled connection string (sslmode=require).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Long random secret for signing sessions. Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me

# The site's public origin (no trailing slash). Magic links are built from this.
BETTER_AUTH_URL=https://codeclub.wales

# Resend — sends the magic-link emails. Key at https://resend.com/api-keys
# The "from" address must be on a domain you've verified in Resend.
RESEND_API_KEY=re_...
EMAIL_FROM=Code Club Wales <login@codeclub.wales>

# THE ALLOW-LIST. Comma-separated emails. Only these can sign in at all —
# everyone else is rejected before any link is sent. Edit this to add/remove Crew.
ALLOWED_EMAILS=organiser@example.com, kid1@example.com, kid2@example.com
